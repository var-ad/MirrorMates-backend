    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "mongoose": "^8.7.1",
    "morgan": "^1.10.0",
    "pg": "^8.13.0",
    "prisma": "^7.6.0",
