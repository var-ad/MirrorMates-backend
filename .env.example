NODE_ENV=development
PORT=4000
# Canonical frontend URL used for invite links and QR codes.
FRONTEND_URL=https://mirrormates.varad.fyi
# Extra browser origins allowed for CORS. Keep localhost here for testing.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,https://mirrormates.varad.fyi
# Supabase Postgres connection string from Project Settings -> Database.
POSTGRES_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
POSTGRES_SSL=true
# MongoDB Atlas SRV connection string from your cluster connect dialog.
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<cluster-name>.mongodb.net/johari_arena?retryWrites=true&w=majority&appName=MirrorMates
MONGODB_APP_NAME=MirrorMates Backend
# Optional workaround for Windows/ISP DNS setups that refuse SRV lookups for Atlas.
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
# Google Identity Services web client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=
# Optional: restrict Google sign-in to a Workspace domain like varad.fyi.
GOOGLE_HOSTED_DOMAIN=
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
